# Required target
MOVIE_NAME=Jana Nayagan
CITY=Chennai

# Preferred theatre config with id/provider/priority metadata.
# Set this to a JSON array, or put the JSON in a file and set THEATRES_FILE.
THEATRES_JSON=
THEATRES_FILE=

# Backward-compatible simple CSV override. If set, priority/provider metadata is not available.
THEATRES=

# Polling
POLL_INTERVAL=5m
RUN_ONCE=true
LOG_LEVEL=info
NOTIFICATION_MODE=state-change
STATE_FILE=.watcher/state.json
DISCOVERY_DIR=.watcher/discovery

# Providers
PROVIDERS=bookmyshow,district
BROWSER_FALLBACK=true
PLAYWRIGHT_HEADLESS=true
PROVIDER_TIMEOUT_MS=30000

# Optional API endpoint overrides discovered from network traffic.
# Value can be JSON:
# [{"method":"GET","url":"https://example.com/api?...","headers":{"x-app":"web"}}]
# Or a comma-separated list of GET URLs.
BOOKMYSHOW_API_ENDPOINTS=
DISTRICT_API_ENDPOINTS=

# Optional discovery start URLs. Defaults are city-specific listing pages.
BOOKMYSHOW_START_URLS=
DISTRICT_START_URLS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_MS=10000
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=false

# Failure behavior
FAIL_ON_PROVIDER_ERROR=false
FAIL_ON_NOTIFICATION_ERROR=true
